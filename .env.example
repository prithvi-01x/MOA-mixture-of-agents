# MOA — Environment Variables Example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# ── Storage ─────────────────────────────────────────────────────────────────
DB_PATH=~/.moa/moa.db
CONFIG_PATH=~/.moa/config.json

# ── Providers ───────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# OpenRouter API key (optional — only required if using OpenRouter models)
# OPENROUTER_API_KEY=sk-or-...

# Bytez API key (optional — only required if using Bytez models)
# BYTEZ_API_KEY=...

# ── Frontend ────────────────────────────────────────────────────────────────
# URL of the backend API as seen by the browser
VITE_API_URL=http://localhost:8000
qw
# ── Logging ─────────────────────────────────────────────────────────────────
# Set to "json" for structured newline-delimited JSON logs (e.g. for Datadog)
LOG_FORMAT=
# Override minimum log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
# Set to "true" to enable the GET /api/logs endpoint
DEBUG=false

# ── Performance ─────────────────────────────────────────────────────────────
# httpx connection-pool limits
HTTPX_MAX_CONNECTIONS=20
HTTPX_MAX_KEEPALIVE_CONNECTIONS=10
# Total request timeout in seconds (connect + read + write)
HTTPX_TIMEOUT=30.0

# ── Retry ───────────────────────────────────────────────────────────────────
# Maximum provider call attempts (including the first)
RETRY_MAX_ATTEMPTS=3
# Base delay in seconds before the first retry (doubles each attempt)
RETRY_BASE_DELAY=1.0

# ── Streaming ───────────────────────────────────────────────────────────────
# Max number of tokens buffered in the SSE queue before back-pressure kicks in
SSE_QUEUE_SIZE=100
